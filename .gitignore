# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
/TransportTycoon/.utmp/
/TransportTycoon/[Ll]ibrary/
/TransportTycoon/[Tt]emp/
/TransportTycoon/[Oo]bj/
/TransportTycoon/[Bb]uild/
/TransportTycoon/[Bb]uilds/
/TransportTycoon/[Ll]ogs/
/TransportTycoon/[Uu]ser[Ss]ettings/
*.log

# By default unity supports Blender asset imports, *.blend1 blender files do not need to be commited to version control.
/TransportTycoon/*.blend1
/TransportTycoon/*.blend1.meta

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
/TransportTycoon/[Mm]emoryCaptures/

# Recordings can get excessive in size
/TransportTycoon/[Rr]ecordings/

# Uncomment this line if you wish to ignore the asset store tools plugin
# /TransportTycoon/[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
/TransportTycoon/[Aa]ssets/Plugins/Editor/JetBrains*
# Jetbrains Rider personal-layer settings
/TransportTycoon/*.DotSettings.user

# Visual Studio cache directory
/TransportTycoon/.vs/

# macOS specific file organizer
**/.DS_Store

# Gradle cache directory
/TransportTycoon/.gradle/

# Autogenerated VS/MD/Consulo solution and project files
/TransportTycoon/ExportedObj/
/TransportTycoon/.consulo/
/TransportTycoon/*.csproj
/TransportTycoon/*.unityproj
/TransportTycoon/*.sln
/TransportTycoon/*.suo
/TransportTycoon/*.tmp
/TransportTycoon/*.user
/TransportTycoon/*.userprefs
/TransportTycoon/*.pidb
/TransportTycoon/*.booproj
/TransportTycoon/*.svd
/TransportTycoon/*.pdb
/TransportTycoon/*.mdb
/TransportTycoon/*.opendb
/TransportTycoon/*.VC.db

# Unity3D generated meta files
/TransportTycoon/*.pidb.meta
/TransportTycoon/*.pdb.meta
/TransportTycoon/*.mdb.meta

# Unity3D generated file on crash reports
/TransportTycoon/sysinfo.txt

# Mono auto generated files
/TransportTycoon/mono_crash.*

# Builds
/TransportTycoon/*.apk
/TransportTycoon/*.aab
/TransportTycoon/*.unitypackage
/TransportTycoon/*.unitypackage.meta
/TransportTycoon/*.app

# Crashlytics generated file
/TransportTycoon/crashlytics-build.properties

# TestRunner generated files
/TransportTycoon/InitTestScene*.unity*

# Addressables default ignores, before user customizations
/TransportTycoon/ServerData
/TransportTycoon/[Aa]ssets/StreamingAssets/aa*
/TransportTycoon/[Aa]ssets/AddressableAssetsData/link.xml*
/TransportTycoon/[Aa]ssets/Addressables_Temp*
# By default, Addressables content builds will generate addressables_content_state.bin
# files in platform-specific subfolders, for example:
# /Assets/AddressableAssetsData/OSX/addressables_content_state.bin
/TransportTycoon/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting auto-generated files
/TransportTycoon/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/TransportTycoon/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
/TransportTycoon/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
/TransportTycoon/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# Auto-generated scenes by play mode tests
/TransportTycoon/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*